# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/rakaez-erp
DB_NAME=rakaez-erp

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Cloudinary
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ZATCA (Saudi E-Invoice)
ZATCA_API_URL=https://api.zatca.gov.sa
ZATCA_API_KEY=your_zatca_api_key

# Frontend URLs
FRONTEND_URL=http://localhost:3000
MOBILE_APP_URL=rakaez://

# Admin
ADMIN_EMAIL=admin@rakaez.sa
ADMIN_PASSWORD=admin_password_123
